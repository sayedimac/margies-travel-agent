@{
    ViewData["Title"] = "Chat";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex flex-column flex-grow-1" style="height: calc(100vh - 56px);">
    <!-- Chat messages area -->
    <div id="chat-messages" class="flex-grow-1 overflow-auto p-3 p-md-4" style="background-color: #f8f9fa;">
        <!-- Welcome message -->
        <div class="d-flex mb-3 align-items-end">
            <div class="me-2 flex-shrink-0">
                <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white"
                     style="width:38px;height:38px;font-size:1.1rem;">
                    <i class="bi bi-robot"></i>
                </div>
            </div>
            <div class="chat-bubble chat-bubble-assistant p-3 rounded-4 shadow-sm"
                 style="max-width:75%;background:#fff;border:1px solid #dee2e6;">
                <p class="mb-0 small">
                    Hello! I'm Margie's Travel Agent, your AI-powered travel assistant. 🌍<br />
                    Ask me anything about travel destinations, itineraries, hotels, or flights.
                    You can also attach an image for context!
                </p>
            </div>
        </div>
    </div>

    <!-- Input area -->
    <div class="border-top bg-white p-3">
        <!-- Image preview -->
        <div id="image-preview-container" class="d-none mb-2 position-relative d-inline-block">
            <img id="image-preview" src="#" alt="Preview" class="rounded"
                 style="max-height:80px;max-width:160px;object-fit:cover;border:2px solid #0d6efd;" />
            <button type="button" id="remove-image" class="btn btn-sm btn-danger position-absolute top-0 end-0 rounded-circle p-0"
                    style="width:20px;height:20px;line-height:1;font-size:0.7rem;" title="Remove image">
                <i class="bi bi-x"></i>
            </button>
        </div>

        <form id="chat-form" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" id="previous-response-id" name="PreviousResponseId" value="" />
            <input type="file" id="image-input" name="Image" accept="image/*" class="d-none" />

            <div class="input-group">
                <button type="button" id="attach-image-btn" class="btn btn-outline-secondary" title="Attach image">
                    <i class="bi bi-paperclip"></i>
                </button>
                <textarea id="message-input" name="Message"
                          class="form-control"
                          placeholder="Ask about travel destinations, flights, hotels..."
                          rows="1"
                          style="resize:none;overflow-y:auto;max-height:120px;"
                          required></textarea>
                <button type="submit" id="send-btn" class="btn btn-primary" title="Send">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
        </form>
        <div class="text-center mt-1">
            <small class="text-muted">Powered by Azure AI Foundry &bull; Margie's Travel Agent</small>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    'use strict';

    const chatMessages   = document.getElementById('chat-messages');
    const chatForm       = document.getElementById('chat-form');
    const messageInput   = document.getElementById('message-input');
    const sendBtn        = document.getElementById('send-btn');
    const attachBtn      = document.getElementById('attach-image-btn');
    const imageInput     = document.getElementById('image-input');
    const imagePreview   = document.getElementById('image-preview');
    const previewContainer = document.getElementById('image-preview-container');
    const removeImageBtn = document.getElementById('remove-image');
    const prevResponseId = document.getElementById('previous-response-id');

    // Auto-resize textarea
    messageInput.addEventListener('input', function () {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 120) + 'px';
    });

    // Attach image button
    attachBtn.addEventListener('click', () => imageInput.click());

    // Image selected
    imageInput.addEventListener('change', function () {
        if (this.files && this.files[0]) {
            const reader = new FileReader();
            reader.onload = e => {
                imagePreview.src = e.target.result;
                previewContainer.classList.remove('d-none');
                previewContainer.classList.add('d-inline-block');
            };
            reader.readAsDataURL(this.files[0]);
        }
    });

    // Remove image
    removeImageBtn.addEventListener('click', () => {
        imageInput.value = '';
        imagePreview.src = '#';
        previewContainer.classList.add('d-none');
        previewContainer.classList.remove('d-inline-block');
    });

    // Send on Enter (Shift+Enter for newline)
    messageInput.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            chatForm.requestSubmit();
        }
    });

    // Submit handler
    chatForm.addEventListener('submit', async function (e) {
        e.preventDefault();

        const message = messageInput.value.trim();
        if (!message) return;

        // Add user message bubble
        const hasImage = imageInput.files && imageInput.files[0];
        appendUserMessage(message, hasImage ? imagePreview.src : null);

        const formData = new FormData(chatForm);

        // Disable input while waiting
        setLoading(true);

        try {
            const response = await fetch('/Chat/Send', {
                method: 'POST',
                body: formData
            });

            const data = await response.json();

            if (data.success) {
                appendAssistantMessage(data.responseText ?? '');
                prevResponseId.value = data.responseId ?? '';
            } else {
                appendErrorMessage(data.errorMessage ?? 'An unexpected error occurred.');
            }
        } catch (err) {
            appendErrorMessage('Network error: ' + err.message);
        } finally {
            setLoading(false);
            // Clear input
            messageInput.value = '';
            messageInput.style.height = 'auto';
            imageInput.value = '';
            imagePreview.src = '#';
            previewContainer.classList.add('d-none');
            previewContainer.classList.remove('d-inline-block');
        }
    });

    function appendUserMessage(text, imageSrc) {
        const div = document.createElement('div');
        div.className = 'd-flex mb-3 justify-content-end align-items-end';
        let imgHtml = imageSrc
            ? `<div class="mb-1"><img src="${escapeHtml(imageSrc)}" class="rounded" style="max-height:80px;max-width:160px;object-fit:cover;" /></div>`
            : '';
        div.innerHTML = `
            <div class="chat-bubble chat-bubble-user p-3 rounded-4 shadow-sm"
                 style="max-width:75%;background:#0d6efd;color:#fff;">
                ${imgHtml}
                <p class="mb-0 small">${escapeHtml(text)}</p>
            </div>
            <div class="ms-2 flex-shrink-0">
                <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white"
                     style="width:38px;height:38px;font-size:1.1rem;">
                    <i class="bi bi-person-fill"></i>
                </div>
            </div>`;
        chatMessages.appendChild(div);
        scrollToBottom();
    }

    function appendAssistantMessage(text) {
        const div = document.createElement('div');
        div.className = 'd-flex mb-3 align-items-end';
        div.innerHTML = `
            <div class="me-2 flex-shrink-0">
                <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white"
                     style="width:38px;height:38px;font-size:1.1rem;">
                    <i class="bi bi-robot"></i>
                </div>
            </div>
            <div class="chat-bubble chat-bubble-assistant p-3 rounded-4 shadow-sm"
                 style="max-width:75%;background:#fff;border:1px solid #dee2e6;">
                <div class="mb-0 small markdown-content">${renderMarkdown(text)}</div>
            </div>`;
        chatMessages.appendChild(div);
        scrollToBottom();
    }

    function appendErrorMessage(errorText) {
        const div = document.createElement('div');
        div.className = 'd-flex mb-3 align-items-end';
        div.innerHTML = `
            <div class="me-2 flex-shrink-0">
                <div class="rounded-circle bg-danger d-flex align-items-center justify-content-center text-white"
                     style="width:38px;height:38px;font-size:1.1rem;">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
            </div>
            <div class="p-3 rounded-4 shadow-sm"
                 style="max-width:75%;background:#fff3cd;border:1px solid #ffc107;">
                <p class="mb-0 small text-warning-emphasis"><strong>Error:</strong> ${escapeHtml(errorText)}</p>
            </div>`;
        chatMessages.appendChild(div);
        scrollToBottom();
    }

    function appendTypingIndicator() {
        const div = document.createElement('div');
        div.id = 'typing-indicator';
        div.className = 'd-flex mb-3 align-items-end';
        div.innerHTML = `
            <div class="me-2 flex-shrink-0">
                <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white"
                     style="width:38px;height:38px;font-size:1.1rem;">
                    <i class="bi bi-robot"></i>
                </div>
            </div>
            <div class="p-3 rounded-4 shadow-sm"
                 style="background:#fff;border:1px solid #dee2e6;">
                <div class="typing-dots">
                    <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                </div>
            </div>`;
        chatMessages.appendChild(div);
        scrollToBottom();
    }

    function removeTypingIndicator() {
        const indicator = document.getElementById('typing-indicator');
        if (indicator) indicator.remove();
    }

    function setLoading(loading) {
        sendBtn.disabled = loading;
        messageInput.disabled = loading;
        attachBtn.disabled = loading;
        if (loading) {
            sendBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span>';
            appendTypingIndicator();
        } else {
            sendBtn.innerHTML = '<i class="bi bi-send-fill"></i>';
            removeTypingIndicator();
        }
    }

    function scrollToBottom() {
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.appendChild(document.createTextNode(text));
        return div.innerHTML;
    }

    // Simple Markdown renderer: bold, italic, code, line breaks, numbered lists, bullets
    function renderMarkdown(text) {
        let html = escapeHtml(text);
        // Code blocks
        html = html.replace(/```([\s\S]*?)```/g, '<pre class="bg-light p-2 rounded small"><code>$1</code></pre>');
        // Inline code
        html = html.replace(/`([^`]+)`/g, '<code class="bg-light px-1 rounded">$1</code>');
        // Bold
        html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
        // Italic
        html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
        // Headings (## and #)
        html = html.replace(/^### (.+)$/gm, '<h6 class="fw-bold mt-2 mb-1">$1</h6>');
        html = html.replace(/^## (.+)$/gm, '<h5 class="fw-bold mt-2 mb-1">$1</h5>');
        html = html.replace(/^# (.+)$/gm, '<h4 class="fw-bold mt-2 mb-1">$1</h4>');
        // Unordered list items
        html = html.replace(/^\- (.+)$/gm, '<li>$1</li>');
        html = html.replace(/(<li>.*<\/li>)/gs, '<ul class="mb-1 ps-3">$1</ul>');
        // Line breaks
        html = html.replace(/\n/g, '<br />');
        return html;
    }
}());
</script>
<style>
    .typing-dots { display: flex; align-items: center; gap: 4px; }
    .dot {
        display: inline-block; width: 7px; height: 7px;
        background: #0d6efd; border-radius: 50%;
        animation: bounce 1.2s infinite ease-in-out;
    }
    .dot:nth-child(2) { animation-delay: 0.2s; }
    .dot:nth-child(3) { animation-delay: 0.4s; }
    @@keyframes bounce {
        0%, 80%, 100% { transform: scale(0.8); opacity: 0.5; }
        40% { transform: scale(1.2); opacity: 1; }
    }
    #chat-messages { scroll-behavior: smooth; }
    .chat-bubble { word-break: break-word; }
</style>
}
